{
  "name": "StudyLocation",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "cafe",
        "library",
        "coworking",
        "university",
        "park",
        "other"
      ]
    },
    "latitude": {
      "type": "number"
    },
    "longitude": {
      "type": "number"
    },
    "has_wifi": {
      "type": "boolean",
      "default": false
    },
    "has_outlets": {
      "type": "boolean",
      "default": false
    },
    "has_outside_seating": {
      "type": "boolean",
      "default": false
    },
    "has_beverages": {
      "type": "boolean",
      "default": false
    },
    "has_food": {
      "type": "boolean",
      "default": false
    },
    "inside_seats": {
      "type": "string",
      "enum": [
        "<10",
        "11-30",
        "31-50",
        "51-100",
        "100+"
      ]
    },
    "outside_seats": {
      "type": "string",
      "enum": [
        "none",
        "<10",
        "11-30",
        "31-50",
        "51-100",
        "100+"
      ]
    },
    "menu_url": {
      "type": "string"
    },
    "noise_level": {
      "type": "string",
      "enum": [
        "quiet",
        "moderate",
        "loud"
      ]
    },
    "hours": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "image_urls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Multiple photos"
    },
    "rating": {
      "type": "number"
    }
  },
  "required": [
    "name",
    "category",
    "latitude",
    "longitude"
  ]
}