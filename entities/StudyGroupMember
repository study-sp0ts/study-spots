{
  "name": "StudyGroupMember",
  "type": "object",
  "properties": {
    "group_id": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "host",
        "member",
        "applicant",
        "invited"
      ],
      "default": "member"
    },
    "status": {
      "type": "string",
      "enum": [
        "confirmed",
        "pending",
        "rejected"
      ],
      "default": "confirmed"
    }
  },
  "required": [
    "group_id",
    "user_email"
  ]
}